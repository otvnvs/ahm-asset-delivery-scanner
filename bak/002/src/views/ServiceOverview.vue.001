<template>
  <div class="view-wrapper overview-wrapper">
    <div class="view-header">Overview: {{ entityName }}</div>

    <div v-if="loading" class="status-box text-center">Fetching live row entities...</div>
    <div v-else-if="errorMessage" class="status-box error-txt text-center">{{ errorMessage }}</div>
    
    <div v-else class="data-container">
      
      <!-- Minimal Search Accent Bar -->
      <div class="search-container">
        <input 
          type="text" 
          v-model="searchQuery" 
          placeholder="Type keyword to search grid matrix..." 
          class="minimal-search-input"
        />
      </div>

      <p class="record-count">
        Rows: {{ filteredItems.length }} / {{ recordItems.length }}
      </p>

      <div v-if="filteredItems.length === 0" class="status-box text-center">No matching rows found in grid matrix.</div>

      <!-- MENDIX STYLE TWO-AXIS SCROLLABLE DATAGRID CONTAINER -->
      <div v-else class="datagrid-scroll-frame">
        <table class="mendix-dark-grid">
          <thead>
            <tr>
              <th class="index-hdr">#</th>
              <!-- Extract headers dynamically from first available record properties -->
              <th v-for="header in gridHeaders" :key="header">
                {{ header }}
              </th>
            </tr>
          </thead>
          <tbody>
            <tr v-for="(row, rowIndex) in filteredItems" :key="rowIndex">
              <td class="index-cell">{{ rowIndex + 1 }}</td>
              <td v-for="header in gridHeaders" :key="header">
                <!-- Fallback to dash symbol if field properties return empty or null values -->
                {{ row[header] !== null && row[header] !== undefined && row[header] !== '' ? row[header] : '-' }}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="button-row">
      <router-link to="/services" class="action-btn back-btn">➔ Return to Services</router-link>
    </div>
  </div>
</template>

<script setup>
import { ref, onMounted, computed } from 'vue';
import { useRoute } from 'vue-router';
import { store } from '../util/store.js';

const route = useRoute();
const entityName = route.params.entityName;

const recordItems = ref([]);
const searchQuery = ref('');
const loading = ref(true);
const errorMessage = ref('');

// Helper method filtering out noise properties like metadata links (__metadata / @odata.context)
const filterFields = (rowObject) => {
  const cleanObject = {};
  if (!rowObject) return cleanObject;
  for (const [key, value] of Object.entries(rowObject)) {
    if (!key.startsWith('@') && !key.startsWith('__') && typeof value !== 'object') {
      cleanObject[key] = value;
    }
  }
  return cleanObject;
};

// COMPUTE HEADERS DYNAMICALLY: Scans the dataset rows to compile column layouts automatically
const gridHeaders = computed(() => {
  if (recordItems.value.length === 0) return [];
  // Uses keys from the first record entry row item to layout column structures
  return Object.keys(filterFields(recordItems.value[0]));
});

// SEARCH QUERY ENGINE
const filteredItems = computed(() => {
  const query = searchQuery.value.trim().toLowerCase();
  if (!query) return recordItems.value;

  return recordItems.value.filter(row => {
    const cleanFields = filterFields(row);
    return Object.values(cleanFields).some(val => 
      String(val).toLowerCase().includes(query)
    );
  });
});

onMounted(async () => {
  const { odataUrl, username, password } = store.config || {};
  const cleanBase = odataUrl.replace(/\/+$/, '');
  const targetEndpoint = `${cleanBase}/${entityName}`;

  try {
    const credentials = btoa(`${username}:${password}`);
    const response = await fetch(targetEndpoint, {
      method: 'GET',
      headers: {
        'Authorization': `Basic ${credentials}`,
        'Accept': 'application/json'
      }
    });

    if (!response.ok) throw new Error(`HTTP Error status ${response.status}`);
    
    const payload = await response.json();
    recordItems.value = payload.value || (Array.isArray(payload) ? payload : [payload]);
  } catch (err) {
    console.error("[GRID DATA FETCH ERROR]:", err);
    errorMessage.value = 'Failed to execute query command against target collection rows.';
  } finally {
    loading.value = false;
  }
});
</script>

<style scoped>
.overview-wrapper { text-align: left; box-sizing: border-box; padding: 0 10px; width: 100%; }

.search-container { margin-top: 15px; margin-bottom: 10px; width: 100%; }
.minimal-search-input {
  font-family: monospace;
  background-color: #1a1a1a;
  color: #4eb5f1;
  border: 1px dashed #444444;
  padding: 10px 12px;
  font-size: 13px;
  outline: none;
  width: 100%;
  box-sizing: border-box;
  border-radius: 4px;
}
.minimal-search-input:focus { border-color: #4eb5f1; background-color: #222222; }
.minimal-search-input::placeholder { color: #555555; }

.record-count { font-family: monospace; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 12px; }

/* TWO-AXIS DATA MATRIX SCROLL FRAME (Bypasses parent viewport clipping limits) */
.datagrid-scroll-frame {
  width: 100%;
  overflow-x: auto; /* Enables swipe-scrolling horizontally for ultra wide column fields */
  overflow-y: auto; /* Enables native desktop/mobile vertical navigation layout loops */
  max-height: 480px; /* Constrains column stacks neatly above action controls bars */
  border: 1px solid #2d2d2d;
  background-color: #111111;
}

/* MENDIX-DARK DATAGRID STYLING PROFILE CONFIGURATIONS */
.mendix-dark-grid {
  border-collapse: collapse;
  width: 100%;
  font-family: monospace;
  font-size: 12px;
  text-align: left;
  white-space: nowrap; /* Prevents cell sentences wrapping weirdly on lines breakouts */
}

/* STICKY DATA MATRIX GRID HEADERS CHASSIS */
.mendix-dark-grid th {
  position: sticky;
  top: 0;
  background-color: #1c1c1c;
  color: #888888;
  font-weight: bold;
  text-transform: uppercase;
  font-size: 11px;
  padding: 10px 16px;
  border-bottom: 2px solid #2d2d2d;
  border-right: 1px solid #2d2d2d;
  z-index: 2;
}

/* MATRIX CELLS CONFIGURATION PANEL LAYOUTS */
.mendix-dark-grid td {
  padding: 10px 16px;
  color: #ffffff;
  border-bottom: 1px solid #222222;
  border-right: 1px solid #222222;
}

/* ALTERNATING ROW STRIPING PROFILE COLORS FOR ULTRA QUICK SCANNING */
.mendix-dark-grid tbody tr:nth-child(even) {
  background-color: #161616;
}

/* ROW HIGHLIGHT INDICATION FEEDBACK TRACKER MOUSE-OVERS */
.mendix-dark-grid tbody tr:hover {
  background-color: #202020;
}

/* INDEX ROW DECORATOR CAPSULES MAPPING STATS */
.index-hdr, .index-cell {
  text-align: center !important;
  font-weight: bold;
  background-color: #1a1a1a !important;
  color: #555555 !important;
  border-right: 2px solid #2d2d2d !important;
  width: 40px;
}

.button-row { margin-top: 25px; }
.action-btn { font-family: monospace; font-size: 14px; padding: 12px 16px; cursor: pointer; text-align: center; border-radius: 4px; text-decoration: none; display: block; width: 100%; box-sizing: border-box; }
.back-btn { background: transparent; color: #ffffff; border: 1px solid #444; }
.back-btn:hover { background: rgba(255, 255, 255, 0.05); }

.status-box { font-family: monospace; font-size: 13px; color: #888; padding: 25px 0; }
.error-txt { color: #e63946; }
.text-center { text-align: center; }
</style>

